---
// Features.astro

// Sección en la landing que lista tres características clave del producto/servicio
// con icono de check. Usada en la página principal.

import {Image} from 'astro:assets'
import f1 from '../../assets/images/f1.png'
import f2 from '../../assets/images/f2.png'
import f3 from '../../assets/images/f3.png'

const {
  label = "NUESTRAS FÓRMULAS",
  title = "Productos con vitaminas y nutracéuticos que hacen la diferencia",
  description = "Nuestros productos son pensados para personas que valoran su salud y buscan opciones confiables, bien fundamentadas y de calidad superior.",
  features = [
    {
      image: f2,
      imageAlt: "Formulaciones diferenciadas",
      title: "Formulaciones diferenciadas",
      description: "Productos diferenciados diseñados específicamente para resultados medibles.",
    },
    {
      image: f1,
      imageAlt: "Respaldo científico",
      title: "Respaldo científico",
      description: "Cada formulación está desarrollada con evidencia de laboratorio y estudios rigurosos.",
    },
    {
      image: f3,
      imageAlt: "Alta gama",
      title: "Alta gama",
      description: "Calidad superior en cada producto, elaborada con los más altos estándares.",
    },
  ],
} = Astro.props;

---

<section class="features section-container">
  <div class="container">
    <div class="top">
      <div class="title">
        <div class="top-label">
          <span>
{label} 
          </span>
          <div class="line"></div>
        </div>
        <h2>{title}</h2>
      </div>
      <div class="desc">
        <p>{description}</p>
      </div>
    </div>
    <div class="content">
      {features.map((feature: any) => (
        <div class="card">
          <Image 
            src={feature.image} 
            alt={feature.imageAlt} 
            width={300} 
            class="card-img" 
          />
          <h5>{feature.title}</h5>
          <p>{feature.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .container {
    display: flex;
    flex-direction: column;
    gap: 48px;
  }

.top-label {
    font-family: "Roboto Mono";
    width: 60%;
    font-size: 18px;
    font-weight: 400;
    display: flex;
    align-items: center;
    justify-content: center;
    text-wrap: nowrap;
    gap: 8px;
    color: var(--grey-300);
  }

.top-label .line {
    width: 100%;
    height: 1px;
    background-color: var(--color-light-gray);
  }

  .top {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 16px;
    align-items: end;
  }

  .title {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  
  .content {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 16px;
  }

  .card {
    position: relative;
    aspect-ratio: 7/5;
    color: white;
    display: flex;
    align-items: flex-start;
    justify-content: end;
    flex-direction: column;
    padding: 24px;
    gap: 8px;
    border-radius: 6px;
    overflow: hidden;
  }

  .card-img {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: -9;
  }

  .card h5 {
    color: white;
    font-size: 24px;
    font-weight: 500;
  }

  .card p {
    font-weight: 400;
    font-size: 16px;
  }

  @media (max-width: 1200px) {
    .top {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 768px) {
    .content {
      grid-template-columns: 1fr;
    }
  }
</style>
