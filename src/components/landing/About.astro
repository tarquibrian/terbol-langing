---
// About.astro
//
// Sección informativa sobre la misión/propósito de Térbol Inspira. Incluye
// texto explicativo y puede incluir imagen de acompañamiento.
//
// Props:
//   - label: Etiqueta superior (default: "QUIÉNES SOMOS")
//   - title: Título principal de la sección
//   - description: Descripción principal
//   - secondaryDescription: Descripción secundaria (opcional)
//   - buttonText: Texto del botón
//   - buttonHref: URL del botón
//   - features: Array de características a mostrar
// -----------------------------------------------------------------------------

import { Image } from "astro:assets";
import Button from "../common/Button.astro";
import FeatureCard from "../common/FeatureCard.astro";
import IconPassion from "../icons/IconPassion.astro";
import IconQuality from "../icons/IconQuality.astro";
import IconRespect from "../icons/IconRespect.astro";
import IconPurpose from "../icons/IconPurpose.astro";
import bg from "../../assets/images/image4.png";

const {
  label = "QUIÉNES SOMOS",
  title = "Tu bienestar es nuestra prioridad",
  description = "Durante más de 40 años, <b>térbol</b> ha cultivado un legado basado en la ciencia, la excelencia y un propósito claro: mejorar la vida de las personas. Hoy, ese mismo espíritu evoluciona con <b>Térbol Inspira</b>, una propuesta creada para acompañarte en un camino de bienestar real.",
  secondaryDescription = "Cada avance, cada innovación y cada producto reflejan nuestra convicción: el equilibrio es la forma más auténtica de transformar la vida.",
  buttonText = "VER CATÁLOGO",
  buttonHref = "https://terbol.com.bo/#",
  features = [
    {
      title: "Pasión",
      description: "Trabajamos con pasión por la salud y el bienestar de las personas.",
      icon: IconPassion,
    },
    {
      title: "Calidad",
      description: "En todos nuestros procesos, productos y servicios.",
      icon: IconQuality,
    },
    {
      title: "Respeto",
      description: "Es el principal componente de nuestro entorno laboral.",
      icon: IconRespect,
    },
    {
      title: "Propósito",
      description: "Brindar salud y bienestar a la vida.",
      icon: IconPurpose,
    },
  ],
} = Astro.props;
---

<section class="about section-container">
  
  <div class="container">
<div class="background">
<Image
        src={bg}
        alt={"Background image"}
        width={300}
        class="background-image"
      />
  </div>
    <div class="content">
      <div class="top-label">
        <span>{label}</span>
        <div class="line"></div>
      </div>
      <h2>{title}</h2>
      <p set:html={description} />
      {secondaryDescription && <p>{secondaryDescription}</p>}

      <Button
        variant="secondary"
        size="sm"
        href={buttonHref}
        target="_blank"
        rel="noopener noreferrer">{buttonText}</Button
      >
    </div>

    <div class="cards-container">
      {features.map((feature: any) => (
        <FeatureCard title={feature.title} description={feature.description}>
          <feature.icon slot="icon" />
        </FeatureCard>
      ))}
    </div>
  </div>
</section>

<style>
  .background {
    position: absolute;
    top: 0;
    right: 0;
    object-fit: cover;
    z-index: 1;
    transform: translateY(-5%);
  }

  .container {
    position: relative;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: center;
  }

  .top-label {
    font-family: "Roboto Mono";
    width: 70%;
    font-size: 18px;
    font-weight: 400;
    display: flex;
    align-items: center;
    justify-content: center;
    text-wrap: nowrap;
    gap: 8px;
    color: var(--grey-300);
  }

  .top-label .line {
    width: 100%;
    height: 1px;
    background-color: var(--color-light-gray);
  }

  .content {
    display: flex;
    flex-direction: column;
    align-items: start;
    gap: 24px;
  }

  .cards-container {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
  }

  @media (max-width: 1200px) {
    .container {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 768px) {
    .button {
      width: 100%;
    }
    .cards-container {
      grid-template-columns: 1fr;
    }
  }
</style>
