---
import Button from "../common/Button.astro";
import { Image } from "astro:assets";
import bannerImg from "../../assets/images/bannerproducts.png";
import bannerBG from "../../assets/images/banner.png";

const {
  topLabel = "Únete a nuestro equipo",
  title = "Inspira tu camino<br> hacia el bienestar",
  description = "Sumate a una comunidad que cree en tu potencial y forma parte de la red de asesores de térbolI Inspira donde tu crecimiento personal y profesional van de la mano.",
  secondaryDescription = "Este es tu momento para inspire, crecer y transformar tu vida.",
  buttonText = "REGISTRARSE COMO ASESOR DE VENTAS",
  secondaryButtonText = "REGISTRO ASESOR DE VENTAS",
  buttonHref = "https://terbol.info/VentaPorCatalogo/QAS/incorporacionwizard",
  image = bannerImg,
  imageAlt = "Banner image",
} = Astro.props;
---

<section class="banner section-container">
  <div class="container">
    <div class="banner-container">
      <div class="content">
        <div class="title">
          <div class="top-label">{topLabel}</div>
          <h3 set:html={title} />
          {description && <p set:html={description} />}
          {secondaryDescription && <p set:html={secondaryDescription} />}
        </div>
        <Button
          variant="secondary"
          size="md"
          class="full"
          target="_blank"
          rel="noopener noreferrer"
          href={buttonHref}>{buttonText}</Button
        >
        <Button
          variant="secondary"
          size="sm"
          class="compact"
          target="_blank"
          rel="noopener noreferrer"
          href={buttonHref}>{secondaryButtonText}</Button
        >
      </div>
      <div class="picture">
        <Image src={image} alt={imageAlt} width={900} class="card-img" />
      </div>
      <Image src={bannerBG} alt={imageAlt} width={1300} class="banner-bg" />
    </div>
  </div>
</section>

<style>
  .banner-bg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: -1;
  }
  .picture {
    width: 100%;
    min-width: 500px;
  }

  .card-img {
    width: 100%;
    height: auto;
    object-fit: cover;
  }

  .compact {
    display: none;
  }
  h3 {
    font-size: clamp(32px, 5vw, 50px);
    font-weight: 600;
    line-height: 115%;
    color: var(--grey-900);
  }

  .banner-container {
    color: var(--grey-900);
    border-radius: 8px;
    overflow: hidden;
    height: 580px;
    display: flex;
    align-items: center;
    /* padding: 64px; */
    gap: 16px;
    position: relative;
  }

  .content {
    display: flex;
    flex-direction: column;
    align-items: start;
    justify-content: start;
    gap: 32px;
    min-width: 480px;
    padding: 64px;
    padding-right: 0;
    max-width: 580px;
  }
  .title {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .top-label {
    font-family: "Roboto";
    font-size: 18px;
    font-weight: 500;
    color: var(--grey-400);
    text-transform: uppercase;
  }

  @media (max-width: 768px) {
    .content {
      min-width: inherit;
      padding: 48px;
      padding-bottom: 0;
      justify-content: start;
      align-items: start;
    }
    .picture {
      width: 100%;
      height: auto;
    }
    .banner-container {
      flex-direction: column;
      height: fit-content;
      align-items: start;
      /* padding-inline: 48px; */
    }

    .compact {
      display: flex;
    }

    .full {
      display: none;
    }
  }

  @media (max-width: 480px) {
    .content {
      padding: 24px;
      padding-top: 48px;
      padding-bottom: 0;
    }
    .banner-container {
      padding: 0px;
      height: fit-content;
      align-items: start;
      flex-direction: column;
      justify-content: start;
    }

    .compact {
      width: 100%;
    }

    .picture {
      min-width: 400px;
    }
  }
</style>
