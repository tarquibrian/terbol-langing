---
// -----------------------------------------------------------------------------
// Hero.astro
//
// Sección principal de la página de aterrizaje. Muestra título, texto
// introductorio, botones de acción y características destacadas junto a una
// imagen representativa (hero image). Usado en la página `src/pages/index.astro`.
//
// Props: ninguno. Todos los contenidos están embebidos estáticamente.
// Dependencias:
//   - <Button>    : componente de botón reutilizable
//   - <Capsule>   : pequeño elemento estilizado para promocionar mensajes
//   - <CircleCheck>: icono usado en la lista de características.
//
// -----------------------------------------------------------------------------

import { Image } from "astro:assets";
import heroImage from "../../assets/images/heroimg.png";
import Button from "../common/Button.astro";
import Capsule from "../common/Capsule.astro";
import CircleCheck from "../icons/CircleCheck.astro";

const {
  capsuleText = "Nueva Línea Premium",
  title = "Inspiramos bienestar, transformamos vidas",
  description = "En un mundo que avanza con velocidad, elegimos el valor del equilibrio. Así nace térbol I Inspira: una invitación a vivir más y vivir mejor, desde la ciencia, la conciencia y la excelencia.",
  buttonText = "REGISTRARME COMO PROMOTORA",
  buttonHref = "https://terbol.com.bo/#",
  features = [
    { text: "Respaldo científico" },
    { text: "Alta gama" },
    { text: "Modelo B2C" },
  ],
  image = heroImage,
  imageAlt = "Hero image",
} = Astro.props;
---

<section class="hero section-container">
  <div class="container">
    <div class="content">
      <Capsule>{capsuleText}</Capsule>
      <h1 set:html={title} />
      <p set:html={description} />

      <Button
        variant="primary"
        size="md"
        class="full"
        href={buttonHref}
        target="_blank"
        rel="noopener noreferrer">{buttonText}</Button
      >
      <Button variant="primary" size="sm" class="compact" href={buttonHref}
        >{buttonText}</Button
      >
      <div class="features">
        {features.map((feature: any) => (
          <div class="feature">
            <CircleCheck />
            {feature.text}
          </div>
        ))}
      </div>
    </div>

    <div class="picture">
      <Image src={image} alt={imageAlt} width={800} class="hero-img" />
    </div>
  </div>
</section>

<style>
  .hero {
    padding-top: 100px;
  }

  .compact {
    display: none;
  }
  .container {
    display: flex;
    justify-content: space-between;
    align-items: center;
    align-self: stretch;
    gap: 32px;
  }
  .content {
    display: flex;
    width: 825px;
    flex-direction: column;
    align-items: flex-start;
    gap: 24px;
  }

  h1 {
    color: var(--text-blue-900);
    font-size: 100px;
    font-size: clamp(40px, 6vw, 80px);
    font-style: normal;
    font-weight: 700;
    line-height: 100%;
  }

  .content p {
    font-style: normal;
    font-weight: 400;
  }

  .picture {
    display: flex;
    width: 502px;
    height: 446px;
    flex-direction: column;
    align-items: flex-start;
    gap: 10px;
    border-radius: 8px;
    overflow: hidden;
    min-width: 400px;
  }

  .hero-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .features {
    display: flex;
    align-items: start;
    justify-content: start;
    gap: 32px;
    flex-wrap: wrap;
  }

  .feature {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
  }

  @media (max-width: 1200px) {
    .container {
    }
  }

  @media (max-width: 1024px) {
    .container {
      flex-direction: column;
    }

    .content {
      width: 100%;
    }

    .picture {
      width: 100%;
    }
  }

  @media (max-width: 768px) {
    .features {
      gap: 16px;
    }
    .picture {
      min-width: inherit;
      aspect-ratio: 3/2;
      height: 100%;
      width: auto;
    }

    .compact {
      display: flex;
      width: 100%;
    }

    .full {
      display: none;
    }
  }
</style>
