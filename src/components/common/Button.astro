---
// -----------------------------------------------------------------------------
// Button.astro
//
// Componente polimórfico para botones y enlaces estilizados. Si se pasa la
// propiedad `href`, renderiza un `<a>`; de lo contrario utiliza `<button>`.
// Soporta variantes de estilo (primaria, secundaria, ghost, etc.) y tamaños.
//
// Props:
//   - variant (string): 'primary' | 'secondary' | 'terciary' | 'outline' | 'ghost'
//   - size    (string): 'sm' | 'md' | 'lg'
//   - href    (string): URL; desencadena elemento <a>.
//   - noIcon  (boolean): oculta el icono de flecha si es verdadero.
//   - class   (string): clases CSS adicionales.
//   - ...rest (object): otras propiedades HTML válidas (target, rel, etc.)
//
// -----------------------------------------------------------------------------

const { 
  variant = 'primary', 
  size = 'md', 
  href, 
  noIcon,
  class: className, 
  ...rest 
} = Astro.props;

// Lógica Polimórfica: Si hay href es un <a>, sino un <button>
const Tag = href ? 'a' : 'button';
---

<Tag 
  href={href}
  class:list={[
    'btn', 
    `btn-${variant}`, 
    `btn-${size}`, 
    className
  ]}
  {...rest}
>
  <slot />
  <div class={`${noIcon ? "none" : "icon"}`}>
    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-arrow-right-icon lucide-arrow-right"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
  </div>
</Tag>

<style>
  .none {
    display: none;
  }
  .icon {
    display: flex;
    margin-top: -2px;
  }
  .btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    height: 52px;
    cursor: pointer;
    transition: all 0.2s ease-in-out;
    border: 1px solid transparent;
    text-decoration: none;
    border-radius: 6px;
    font-size: 18px;
    font-weight: 500;

    text-wrap: nowrap;
    font-size: 18px;
    font-style: normal;
    line-height: 25px; /* 138.889% */
    text-transform: uppercase;
  }

  .btn:active {
    transform: scale(0.98);
  }

  .btn-primary {
    background-color: var(--color-orange);
    color: black;
  }

  .btn-secondary {
    background-color: var(--color-black);
    color: white;
  }

  .btn-terciary {
    font-weight: 600;
    background-color: #ffffff;
  }
  
  .btn-outline {
    background-color: transparent;
    border-color: currentColor;
    color: var(--color-text, #1e293b);
  }

  .btn-outline:hover {
    background-color: rgba(0,0,0, 0.05);
  }

  .btn-ghost {
    background-color: transparent;
    color: var(--color-text);
  }
  .btn-ghost:hover {
    background-color: rgba(0,0,0, 0.05);
  }

  /* 3. Tamaños */
  .btn-sm {
    padding: 4px 12px;
    height: 36px;
    font-size: 0.875rem;
    font-weight: 500;
  }
  
  .btn-md {
    padding: 4px 20px;
    font-size: 18px;
  }
  
  .btn-lg {
    padding: 1rem 2rem;
    font-size: 1.125rem;
  }
</style>
