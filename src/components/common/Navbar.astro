---
import Button from '../common/Button.astro';
import logoTerbol from '../../assets/logo.svg'
---

<nav class="navbar">
  <div class="navbar-container">
    <div class="navbar-content">
    <div class="logo">         
      <img src={logoTerbol.src} width="200" height="33" alt="Logo de Terbol" />
    </div>
    <Button variant="primary" size="md" class="full">
      SOY PROMOTORA
    </Button>
    <Button variant="primary" size="sm" class="compact">
      SOY PROMOTORA
    </Button>

    </div>
  </div>
</nav>

<style>

  .navbar {
    position: fixed;
    background-color: white;
    z-index: 999;
  }

  .navbar-content {
    display: flex;
    justify-content: space-between;
    align-items: center;
    height: 100px;
    border-bottom: 1px solid var(--color-light-gray);
  }

  .compact {
    display: none;
  }

@media (max-width: 1024px) {
  .navbar-container {
    padding-inline: 48px;
  }
}


@media (max-width: 768px) {
  .navbar-container {
    padding-inline: 32px;
  }
.full {
      display: none;
    }

    .compact {
      display: flex;
    }
}

  @media (max-width: 480px) {
    .navbar-container {
          padding-inline: 24px;
    }
    
  }
</style>

