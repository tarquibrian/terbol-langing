---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Product {
  label: string;
  image: ImageMetadata;
  title: string;
  description: string;
  price: string;
  href?: string;
}

interface Props {
  product: Product;
}

const { product } = Astro.props;

const hasHref = product.href && product.href.trim() !== "";
---

{hasHref ? (
  <a href={product.href} target="_blank" rel="noopener noreferrer" class="card-link">
    <div class="card">
      {/* <div class="over-label">{product.label}</div> */}
      <div class="picture">
        <Image
          src={product.image}
          alt={product.title}
          width={300}
          class="card-img"
        />
      </div>
      <div class="card-content">
        <h5>{product.title}</h5>
        <p>{product.description}</p>
      </div>
    </div>
  </a>
) : (
  <div class="card">
    {/* <div class="over-label">{product.label}</div> */}
    <div class="picture">
      <Image
        src={product.image}
        alt={product.title}
        width={400}
        class="card-img"
      />
    </div>
    <div class="card-content">
      <h5>{product.title}</h5>
      <p>{product.description}</p>
    </div>
  </div>
)}

<style>
  .card {
    /* padding: 24px; */
    background: var(--primary-soft-gray);
    border-radius: 6px;
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    width: 100%;
    overflow: hidden;
    height: auto;
    border: 1px solid var(--color-soft-gray);
    transition: border-color 0.3s ease;
  }

  .card:hover {
    border: 1px solid var(--primary-orange);
  }

  .card-link {
    text-decoration: none;
    display: block;
  }

  .card-link:hover .card {
    border: 1px solid var(--primary-orange);
  }

  .over-label {
    position: absolute;
    top: 24px;
    left: 24px;
    background: #ffffff;
    font-family: "Roboto Mono";
    font-size: 15px;
    font-weight: 400;
    padding: 2px 8px;
    border-radius: 4px;
  }

  .picture {
    display: flex;
    align-items: center;
    justify-content: center;
    /* padding: 2rem; 1rem; */
    height: 100%;
    width: 100%;
  }

  .card-img {
    aspect-ratio: 3/3;
    width: 100%;
    height: auto;
    object-fit: cover;
  }

  .card-content {
    display: flex;
    flex-direction: column;
    gap: 8px;
    height: 100%;
    padding: 24px;
    padding-top: 0;
  }

  .card-content h5 {
    font-size: 24px;
    font-weight: 500;
  }

  .card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    margin-top: 8px;
  }

  .card-footer span {
    font-size: 18px;
    font-weight: 600;
  }

  @media (max-width: 1024px) {
    .picture {
      padding: 2rem;
    }
  }

  @media (max-width: 480px) {
    .picture {
      padding: 1rem;
    }
    .card-footer {
      display: flex;
      flex-direction: column;
      align-items: initial;
    }
  }
</style>
