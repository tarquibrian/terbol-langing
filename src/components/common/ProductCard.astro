---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import Button from "../common/Button.astro";

interface Product {
  label: string;
  image: ImageMetadata;
  title: string;
  description: string;
  price: string;
  href: string;
}

interface Props {
  product: Product;
}

const { product } = Astro.props;
---

<div class="card">
  <div class="over-label">{product.label}</div>
  <div class="picture">
    <Image
      src={product.image}
      alt={product.title}
      width={300}
      class="card-img"
    />
  </div>
  <div class="card-content">
    <h5>{product.title}</h5>
    <p>{product.description}</p>
    <div class="card-footer">
      <span class="price">{product.price}</span>
      <Button
        variant="primary"
        size="sm"
        noIcon
        href={product.href}
        target="_blank"
        rel="noopener noreferrer">Comprar</Button
      >
    </div>
  </div>
</div>

<style>
  .card {
    padding: 24px;
    background: var(--primary-soft-gray);
    border-radius: 6px;
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    width: 100%;
    overflow: hidden;
    height: auto;
  }

  .over-label {
    position: absolute;
    top: 24px;
    left: 24px;
    background: #ffffff;
    font-family: "Roboto Mono";
    font-size: 15px;
    font-weight: 400;
    padding: 2px 8px;
    border-radius: 4px;
  }

  .picture {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 3rem;
    height: 100%;
  }

  .card-img {
    aspect-ratio: 3/3;
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .card-content {
    display: flex;
    flex-direction: column;
    gap: 8px;
    height: 100%;
  }

  .card-content h5 {
    font-size: 24px;
    font-weight: 500;
  }

  .card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    margin-top: 8px;
  }

  .card-footer span {
    font-size: 18px;
    font-weight: 600;
  }

  @media (max-width: 1024px) {
    .picture {
      padding: 2rem;
    }
  }

  @media (max-width: 480px) {
    .picture {
      padding: 1rem;
    }
    .card-footer {
      display: flex;
      flex-direction: column;
      align-items: initial;
    }
  }
</style>
