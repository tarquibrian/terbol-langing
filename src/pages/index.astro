---
// -----------------------------------------------------------------------------
// index.astro
//
// Página de aterrizaje principal que ensambla el layout global y las secciones
// de contenido definidas en /src/components/landing. Cada componente tiene
// documentación en su cabecera. No recibe props; se renderiza estáticamente.
//
// Autor: Giro54
// Fecha: 2026-03-02
// -----------------------------------------------------------------------------

import Layout from '../layouts/Layout.astro';
import Navbar from '../components/common/Navbar.astro'
import Hero from '../components/landing/Hero.astro'
import About from '../components/landing/About.astro'
import Products from '../components/landing/Products.astro'
import Features from '../components/landing/Features.astro'
import OurModel from '../components/landing/OurModel.astro'
import Banner from '../components/landing/Banner.astro'
import Footer from '../components/common/Footer.astro'
---

<Layout>
  <Navbar />

  <main>
    <Hero />
    <About />
    <Products />
    <Features />
    <OurModel />
    <Banner />
  </main>

  <Footer />
</Layout>
